rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Allow anyone to upload files under submissions/ (max 100MB)
    match /submissions/{submissionId}/{allPaths=**} {
      allow write: if request.resource.size < 100 * 1024 * 1024;
      // Only admin / Cloud Functions can read — not public
      allow read: if false;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
