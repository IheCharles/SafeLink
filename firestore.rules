rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Submissions: anyone can create and read, only admin can update
    match /submissions/{submissionId} {
      allow create: if
        request.resource.data.keys().hasAll(['email', 'idPhotoUrl', 'verificationType', 'evidenceUrl', 'status', 'createdAt']) &&
        request.resource.data.status == 'pending' &&
        request.resource.data.verificationType in ['lab_report', 'video'];

      allow read: if true;
      allow update, delete: if false;
    }
  }
}